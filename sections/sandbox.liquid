{% comment %}
  {% for item in (1..10) %}
    {% if item > 5 %}
      {% break %}
    {% endif %}

    {{ item }}

    {% unless forloop.last %} , {% endunless %}
  {% endfor %}
{% endcomment %}


{% for collection in collections %}
  {% paginate collection.products by 70, window_size: 2 %}
    {% for product in collection.products %}
      {% if forloop.first %}
        forloop.length - {{ forloop.length }} <br>
      {% endif %}
      
      {{ forloop.index }} - {{ product.title }} <br>
    {% endfor %}

     {{- paginate | default_pagination }}
  {% endpaginate %}
{% endfor %}



{% schema %}
{
  "name": "Sandbox",
  "settings": [],
  "presets": [
    {
      "name": "Sandbox"
    }
  ]
}
{% endschema %}